@app.route("/api/campaigns", methods=["POST"])
@login_required
def create_campaign():
    global _campaign_id
    data = request.json
    target = data.get("target", "High")
    reach  = sum(1 for u in USERS if u["churn"] == target)
    camp = {
        "id":        _campaign_id,
        "name":      data.get("name", "New Campaign"),
        "status":    "Scheduled",
        "target":    target,
        "reach":     reach,
        "opened":    0,
        "converted": 0,
        "created":   datetime.now().strftime("%Y-%m-%d"),
        "type":      data.get("type", "Email"),
        "message":   data.get("message", ""),
    }
    CAMPAIGNS.append(camp)
    _campaign_id += 1
    return jsonify(camp), 201

