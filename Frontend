# ── Export API ────────────────────────────────────────────────────────────────
@app.route("/api/export/csv")
@login_required
def export_csv():
    risk   = request.args.get("risk", "all")
    city   = request.args.get("city", "all")
    limit  = int(request.args.get("limit", 1000))
    users  = USERS
    if risk != "all":
        users = [u for u in users if u["churn"] == risk]
    if city != "all":
        users = [u for u in users if u["city"] == city]
    users = users[:limit]

    si = io.StringIO()
    writer = csv.DictWriter(si, fieldnames=["id","name","city","churn","risk_score",
                                             "transactions","last_active","complaints","phone"])
    writer.writeheader()
    for u in users:
        writer.writerow({k: u[k] for k in ["id","name","city","churn","risk_score",
                                             "transactions","last_active","complaints","phone"]})
    output = make_response(si.getvalue())
    output.headers["Content-Disposition"] = "attachment; filename=clientpulse_export.csv"
    output.headers["Content-type"] = "text/csv"
    return output

