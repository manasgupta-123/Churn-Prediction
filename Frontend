    })

@app.route("/api/map_data")
@login_required
def map_data():
    out = {}
    for city, meta in CITIES.items():
        cu = [u for u in USERS if u["city"]==city]
        total  = len(cu)
        high   = sum(1 for u in cu if u["churn"]=="High")
        medium = sum(1 for u in cu if u["churn"]=="Medium")
        low    = sum(1 for u in cu if u["churn"]=="Low")
        ratio  = high/total if total else 0
        level  = "High" if ratio>=0.03 else ("Medium" if ratio>=0.015 else "Low")
        out[city] = {
            "lat": meta["coords"][0], "lng": meta["coords"][1],
            "state": meta["state"],
            "total": total, "high": high, "medium": medium, "low": low,
            "ratio": round(ratio,4), "level": level,
        }
    return jsonify(out)

@app.route("/api/city/<city_name>")
@login_required
def city_users(city_name):
    page    = int(request.args.get("page", 1))
    risk    = request.args.get("risk", "all")
    search  = request.args.get("search", "").lower()
    per_page = 20
    users = [u for u in USERS if u["city"] == city_name]
    if risk != "all":
        users = [u for u in users if u["churn"] == risk]
    if search:
        users = [u for u in users if search in u["name"].lower()]
    total = len(users)
    users = users[(page-1)*per_page : page*per_page]
    return jsonify({"users": users, "total": total, "page": page, "per_page": per_page})

@app.route("/api/user/<int:user_id>")
@login_required
def user_detail(user_id):
    u = next((u for u in USERS if u["id"] == user_id), None)
    if not u:
        return jsonify({"error": "Not found"}), 404
    # Build a 6-month transaction trend
    trend = []
    months = ["Jun","Jul","Aug","Sep","Oct","Nov"]
    base = u["transactions"]
    for m in months:
        trend.append({"month": m, "txn": max(1, base + random.randint(-5, 5))})
    return jsonify({**u, "trend": trend})

